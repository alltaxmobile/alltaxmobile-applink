{
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/",
      "destination": "/open?screen=home",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/membership",
      "destination": "/open"
    },
    {
      "source": "/payment-methods",
      "destination": "/open"
    },
    {
      "source": "/employedcenter/:id",
      "destination": "/open"
    }
  ],
  "headers": [
    {
      "source": "/.well-known/assetlinks.json",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/json"
        }
      ]
    },
    {
      "source": "/.well-known/apple-app-site-association",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/json"
        }
      ]
    }
  ]
}
